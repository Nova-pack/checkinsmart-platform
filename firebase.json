{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**"
    ],
    "redirects": [
      { "source": "/", "destination": "/landing/", "type": 301 }
    ],
    "rewrites": [
      { "source": "/login",       "destination": "/login/index.html" },
      { "source": "/login/",      "destination": "/login/index.html" },
      { "source": "/login/**",    "destination": "/login/index.html" },
      { "source": "/landing",    "destination": "/landing/index.html" },
      { "source": "/landing/",   "destination": "/landing/index.html" },
      { "source": "/landing/**", "destination": "/landing/index.html" },
      { "source": "/app",        "destination": "/app/index.html" },
      { "source": "/app/**",     "destination": "/app/index.html" },
      { "source": "/booking",    "destination": "/booking/index.html" },
      { "source": "/booking/**", "destination": "/booking/index.html" }
    ],
    "headers": [
      {
        "source": "/**",
        "headers": [
          { "key": "X-Frame-Options",          "value": "DENY" },
          { "key": "X-Content-Type-Options",   "value": "nosniff" },
          { "key": "Strict-Transport-Security","value": "max-age=31536000; includeSubDomains; preload" },
          { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy",       "value": "camera=(), microphone=(), geolocation=(), payment=()" },
          { "key": "Content-Security-Policy",  "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://firestore.googleapis.com https://*.cloudfunctions.net; frame-src https://*.cloudfunctions.net https://sis-t.redsys.es https://sis.redsys.es; frame-ancestors 'none'; object-src 'none'; base-uri 'self'" }
        ]
      },
      {
        "source": "/tenants/**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/assets/config.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/assets/firestore-db.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  }
}
